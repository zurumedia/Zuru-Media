// ---------------- STATE ----------------
let selectedSubjects=[];
let currentQ=0;
let timer=120*60;
let answers={};

// ---------------- SUBJECT SELECTION ----------------
document.querySelectorAll('input[name="subj"]').forEach(cb=>{
cb.onchange=()=>{
selectedSubjects=[...document.querySelectorAll('input[name="subj"]:checked')].map(x=>x.value);
if(selectedSubjects.length>3){
alert("Select only 3 subjects");
cb.checked=false;
}
}
});

function startExam(){
if(selectedSubjects.length!==3){
alert("Select exactly 3 subjects");
return;
}

document.querySelector(".container").style.display="none";
document.getElementById("examBox").style.display="block";

startTimer();
loadQuestion();
}

// ---------------- TIMER ----------------
function startTimer(){
setInterval(()=>{
if(timer<=0){
submitExam();
return;
}
timer--;
document.getElementById("timer").innerText=
Math.floor(timer/60)+":"+("0"+timer%60).slice(-2);
},1000);
}

// ---------------- QUESTIONS ----------------
function getAllSubjects(){
return ["English",...selectedSubjects];
}

function loadQuestion(){
let all=getAllSubjects();
let subject=all[Math.floor(currentQ/10)];
let qIndex=currentQ%10;

document.getElementById("subjectTitle").innerText=subject;

let q=questionBank[subject][qIndex];

document.getElementById("questionBox").innerHTML=`
<h3>Q${currentQ+1}: ${q.q}</h3>
${q.a.map((opt,i)=>`
<div>
<input type="radio" name="opt" onclick="answers[${currentQ}]=${i}">
${opt}
</div>
`).join("")}
`;
}

function nextQ(){
if(currentQ<39){currentQ++;loadQuestion();}
}
function prevQ(){
if(currentQ>0){currentQ--;loadQuestion();}
}

// ---------------- SUBMIT ----------------
function submitExam(){
let score=0;

for(let i=0;i<40;i++){
let subj=getAllSubjects()[Math.floor(i/10)];
let q=questionBank[subj][i%10];
if(answers[i]===q.c)score++;
}

let result=(score/40)*400;

alert("Exam finished. Your score: "+result+"/400");
location.reload();
}
</script>

</body>
</html>
