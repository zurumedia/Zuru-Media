<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Zuru Media CBT Simulator</title>

<style>
body{
margin:0;
font-family:Arial;
background:linear-gradient(135deg,#2b0a0a,#4a0f1f,#1a0505);
color:white;
overflow-x:hidden;
}

/* Center moving text */
#movingText{
position:fixed;
top:40%;
width:100%;
text-align:center;
font-size:18px;
opacity:0.6;
animation:moveText 8s linear infinite;
}

@keyframes moveText{
0%{transform:translateY(0px);}
50%{transform:translateY(-20px);}
100%{transform:translateY(0px);}
}

/* Container */
.container{
max-width:900px;
margin:40px auto;
background:rgba(255,255,255,0.08);
padding:20px;
border-radius:15px;
backdrop-filter:blur(10px);
}

/* Footer */
footer{
position:fixed;
bottom:0;
width:100%;
text-align:center;
padding:10px;
background:rgba(0,0,0,0.5);
font-size:12px;
}
</style>
</head>

<body>

<div id="movingText">
Welcome to Zuru Media CBT Platform • Practice Mode Only • Not Real JAMB Questions
</div>

<div class="container">

<h2>CBT Subject Selection</h2>
<p>English is compulsory. Select exactly 3 subjects.</p>

<form id="subjectForm">

<label><input type="checkbox" checked disabled> English (Compulsory)</label><br>

<label><input type="checkbox" name="subj" value="CRS"> CRS</label><br>
<label><input type="checkbox" name="subj" value="Government"> Government</label><br>
<label><input type="checkbox" name="subj" value="Economics"> Economics</label><br>
<label><input type="checkbox" name="subj" value="Literature"> Literature</label><br>
<label><input type="checkbox" name="subj" value="Marketing"> Marketing</label><br>
<label><input type="checkbox" name="subj" value="Biology"> Biology</label><br>
<label><input type="checkbox" name="subj" value="Physics"> Physics</label><br>
<label><input type="checkbox" name="subj" value="Chemistry"> Chemistry</label><br>
<label><input type="checkbox" name="subj" value="Civic"> Civic Education</label><br><br>

<button type="button" onclick="startExam()">Start Exam</button>
</form>

</div>

<div class="container" id="examBox" style="display:none;">
<h2 id="subjectTitle"></h2>
<div id="timer">120:00</div>
<div id="questionBox"></div>
<button onclick="prevQ()">Previous</button>
<button onclick="nextQ()">Next</button>
<button onclick="submitExam()">Submit</button>
</div>

<footer>
© All Rights Reserved 2026 Zuru Media
</footer>

